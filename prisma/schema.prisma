generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Knowledge {
  id        String   @id @default(cuid())
  content   String
  embedding Float[]
  metadata  Json?
  timestamp DateTime @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  message   String
  response  String
  timestamp DateTime @default(now())

  @@index([sessionId, timestamp])
}

model Session {
  id        String   @id @default(cuid())
  userId    String?
  createdAt DateTime @default(now())
}

model EmbeddingCache {
  id        String   @id @default(cuid())
  text      String   @unique
  embedding Float[]
  createdAt DateTime @default(now())
}
